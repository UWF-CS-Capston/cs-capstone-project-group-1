PORT=5000
JWT_SECRET=replace_with_a_long_random_secret

# Option 1: Use DATABASE_URL
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/gymbuddy

# Option 2: Use explicit PG variables
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=gymbuddy

# Set true when your Postgres provider requires SSL.
DB_SSL=false
