PORT=5000
JWT_SECRET=replace_with_a_long_random_secret

# Network Configuration (optional - for CORS)
# Add your computer's IP address here for CORS configuration
# Find it using: ipconfig (Windows) or ifconfig (macOS/Linux)
# COMPUTER_IP=192.168.1.XXX
# PHONE_IP=192.168.1.XXX

# Option 1: Use DATABASE_URL
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/gymbuddy

# Option 2: Use explicit PG variables
PORT=5001
JWT_SECRET=your-secret-here
PGHOST=localhost
PGPORT=5000
PGUSER=postgres
PGPASSWORD=change_this_password
PGDATABASE=gymbuddy


# Set true when your Postgres provider requires SSL.
DB_SSL=false
