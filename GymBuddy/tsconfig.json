{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "jsx": "react-native",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noImplicitAny": true,
    "types": ["jest", "node"]
  },
  "include": [
    "src/**/*",
    "app/**/*",
    "components/**/*",
    "contexts/**/*",
    "utils/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "actions"
  ]
}