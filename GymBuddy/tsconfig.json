{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-native",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noImplicitAny": true
  },
  "include": [
    "src/**/*",
    "app/**/*",
    "components/**/*",
    "contexts/**/*",
    "utils/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "actions"
  ]
}